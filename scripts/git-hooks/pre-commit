#!/bin/bash
# scripts/git-hooks/pre-commit
# Pre-commit hook para lembrar de atualizar CLAUDE.md

# Cores
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🤖 Checando CLAUDE.md...${NC}"

# Verifica se CLAUDE.md existe
if [ ! -f "CLAUDE.md" ]; then
    echo -e "${RED}❌ CLAUDE.md não encontrado!${NC}"
    echo -e "${YELLOW}💡 Crie um usando o prompt gerador${NC}"
    exit 1
fi

# Verifica se CLAUDE.md está nos arquivos staged
if git diff --cached --name-only | grep -q "CLAUDE.md"; then
    echo -e "${GREEN}✅ CLAUDE.md atualizado neste commit!${NC}"
    exit 0
fi

# Se CLAUDE.md não está staged, verifica quantos commits desde última atualização
LAST_UPDATE=$(git log -1 --format=%cd --date=short -- CLAUDE.md 2>/dev/null || echo "nunca")
COMMITS_SINCE=0

if [ "$LAST_UPDATE" != "nunca" ]; then
    COMMITS_SINCE=$(git log --oneline --since="$LAST_UPDATE" 2>/dev/null | wc -l)
fi

# Alerta se houver muitos commits sem atualizar
if [ "$COMMITS_SINCE" -gt 3 ] || [ "$LAST_UPDATE" = "nunca" ]; then
    echo ""
    echo -e "${YELLOW}⚠️  ATENÇÃO: CLAUDE.md desatualizado!${NC}"
    
    if [ "$LAST_UPDATE" = "nunca" ]; then
        echo -e "${YELLOW}   Nunca foi atualizado neste projeto${NC}"
    else
        echo -e "${YELLOW}   Última atualização: $LAST_UPDATE ($COMMITS_SINCE commits atrás)${NC}"
    fi
    
    echo ""
    echo -e "${BLUE}📝 Como atualizar:${NC}"
    echo "   1. Abra Claude Code ou Cursor"
    echo "   2. Cole: 'Atualize a seção Contexto Atual do CLAUDE.md com as mudanças desta sessão'"
    echo "   3. Salve o output no CLAUDE.md"
    echo "   4. Execute: git add CLAUDE.md"
    echo ""
    
    # Pergunta se quer continuar
    read -p "$(echo -e ${YELLOW}Continuar commit sem atualizar CLAUDE.md? [y/N]${NC} )" -n 1 -r
    echo
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${RED}❌ Commit cancelado${NC}"
        echo -e "${GREEN}💡 Atualize CLAUDE.md e tente novamente${NC}"
        exit 1
    fi
    
    echo -e "${YELLOW}⚠️  Continuando sem atualizar...${NC}"
else
    echo -e "${GREEN}✅ CLAUDE.md OK (atualizado recentemente)${NC}"
fi

exit 0
