# ─── AI Video Editor — Variáveis de Ambiente ─────────────────────────────────
# Copie este arquivo para .env e preencha suas chaves:
#   cp scripts/video-editor/.env.example scripts/video-editor/.env

# OpenAI Whisper API (obrigatório para legendas automáticas)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Higgsfield API (opcional — necessário apenas com --higgsfield)
# Obtenha em: https://cloud.higgsfield.ai/api-keys
HIGGSFIELD_API_KEY=hf-...
