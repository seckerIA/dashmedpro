# Evolution API Configuration
# Copy this file to .env and fill in the values

# Public URL where Evolution API is accessible (with HTTPS for production)
SERVER_URL=https://evo.yourdomain.com

# Global API key for instance management (generate a strong random key)
EVOLUTION_GLOBAL_API_KEY=your-secret-api-key-here

# PostgreSQL connection for Evolution API data
DATABASE_CONNECTION_URI=postgresql://user:password@host:5432/evolution

# Port mapping (default 8081 to avoid conflict with Vite on 8080)
EVO_PORT=8081
